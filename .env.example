# ============================================================
# CloudMail Server - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
NODE_ENV=production
APP_NAME=CloudMail
APP_URL=https://mail.yourdomain.com
ADMIN_URL=https://admin.mail.yourdomain.com
WEBMAIL_URL=https://webmail.yourdomain.com

# --- Server Ports ---
SMTP_PORT=25
SMTP_SUBMISSION_PORT=587
SMTP_SECURE_PORT=465
IMAP_PORT=143
IMAPS_PORT=993
POP3_PORT=110
POP3S_PORT=995
HTTP_PORT=3000
HTTPS_PORT=3443

# --- Database ---
# Local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloudmail
DB_USER=cloudmail
DB_PASSWORD=change_this_strong_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# Managed DB (AWS RDS / Azure Database / DigitalOcean Managed DB)
# DB_HOST=your-db-host.region.rds.amazonaws.com
# DB_SSL=true
# DB_SSL_CA=/path/to/rds-ca-2019-root.pem

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Redis URL (alternative to individual settings)
# REDIS_URL=redis://:password@localhost:6379

# --- TLS/SSL Certificates ---
TLS_KEY=/etc/ssl/private/mail.key
TLS_CERT=/etc/ssl/certs/mail.crt
TLS_CA=/etc/ssl/certs/ca.crt

# Self-signed cert for dev (auto-generated if TLS files don't exist)
TLS_SELF_SIGNED=false

# --- DKIM ---
DKIM_SELECTOR=mail
DKIM_KEY_DIR=/etc/cloudmail/dkim

# --- JWT ---
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# --- Admin ---
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_strong_password

# --- Email Limits ---
MAX_MESSAGE_SIZE_MB=25
MAX_RECIPIENTS_PER_MESSAGE=100
MAX_CONNECTIONS_PER_IP=10
RATE_LIMIT_SMTP=100
RATE_LIMIT_AUTH=10

# --- Bulk Email / Campaigns ---
BULK_EMAIL_CONCURRENCY=10
BULK_EMAIL_DELAY_MS=100
CAMPAIGN_FROM_DOMAIN=yourdomain.com

# --- Spam / Security ---
ENABLE_GREYLISTING=false
BLOCK_KNOWN_SPAM=true
MAX_AUTH_FAILURES=5
AUTH_BAN_DURATION_MIN=30

# --- Storage ---
MAIL_STORAGE_PATH=/var/cloudmail/messages
ATTACHMENT_STORAGE_PATH=/var/cloudmail/attachments
MAX_MAILBOX_SIZE_MB=1024

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=/var/log/cloudmail
LOG_MAX_FILES=30d
LOG_MAX_SIZE=100m

# --- SMTP Relay (outbound) ---
# Leave blank to send directly (requires proper DNS/PTR setup)
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=
SMTP_RELAY_PASS=

# --- Monitoring / Webhooks ---
WEBHOOK_SECRET=
DELIVERY_WEBHOOK_URL=

# --- Cloud Provider Specific ---
# AWS SES (optional alternative outbound transport)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# USE_SES=false

# Azure Communication Services (optional)
# AZURE_EMAIL_ENDPOINT=
# AZURE_EMAIL_KEY=

# DigitalOcean Spaces (object storage for attachments)
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
# DO_SPACES_BUCKET=cloudmail-attachments
